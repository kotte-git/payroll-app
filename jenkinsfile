pipeline {
    agent any

    stages {
        stage('Checkout') {
            steps {
                // Jenkins pulls the latest code from your repo
                checkout scm
            }
        }
        stage('Build') {
            steps {
                // We use 'bat' because your path suggests you are on Windows
                bat 'mvn clean compile'
            }
        }
        stage('Run Payroll Logic') {
            steps {
                bat 'mvn exec:java -Dexec.mainClass="com.payroll.App"'
            }
        }
    }
    post {
        success {
            echo 'Payroll Application Built and Executed Successfully!'
        }
        failure {
            echo 'Build Failed. Check the pom.xml or Java code.'
        }
    }
}
stage('Deploy to Kubernetes') {
    steps {
        // This updates the deployment with the new image built in the previous stage
        bat 'kubectl apply -f deployment.yaml'
        bat 'kubectl rollout restart deployment/payroll-deployment'
    }
}